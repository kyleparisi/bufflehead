#!/bin/bash
# Build the macOS app and package it as a styled DMG.
# Usage: ./bin/release-dmg
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
APP="$ROOT/releases/darwin/universal/Bufflehead.app"
DMG="$ROOT/releases/Bufflehead.dmg"
SETTINGS="$ROOT/packaging/dmg/settings.py"

cd "$ROOT"

echo "Building macOS app..."
GOOS=macos gd build ./cmd/viewer

if [ ! -d "$APP" ]; then
    echo "Error: $APP not found after build" >&2
    exit 1
fi

if ! python3 -c 'import dmgbuild' >/dev/null 2>&1; then
    echo "Error: python package 'dmgbuild' is required to create the styled DMG." >&2
    echo "Install it with: python3 -m pip install --user dmgbuild" >&2
    exit 1
fi

echo "Creating styled DMG..."
rm -f "$DMG"
python3 -m dmgbuild -s "$SETTINGS" "Bufflehead" "$DMG"

echo "Done: $DMG"
ls -lh "$DMG"
