#!/usr/bin/env bash
#
# Source this under MSYS2 UCRT64 to make `go build` / `go test` able to compile
# the cgo packages (go-duckdb) on Windows:
#
#   source bin/setup-gcc142 && go test ./...
#
# go-duckdb's prebuilt libduckdb.a needs emutls symbols that gcc >= 16 dropped,
# so we build against a pinned gcc 14.2 kept in a side prefix (leaving the
# system toolchain untouched). Idempotent — the prefix is built once.
#
# This mirrors the toolchain setup in bin/build-windows; keep the two in sync.
set -euo pipefail

command -v go >/dev/null 2>&1 || export PATH="/c/Program Files/Go/bin:$PATH"

GCCDIR="${GCCDIR:-/c/gcc142}"

if [ ! -x "$GCCDIR/bin/gcc.exe" ]; then
  echo "installing pinned gcc 14.2 -> $GCCDIR"
  # crt + headers provide the mingw C runtime objects (e.g. default-manifest.o
  # that Go needs when linking Windows .exe test binaries — build-windows only
  # links a DLL so it never needed them).
  pacman -S --needed --noconfirm \
    base-devel \
    mingw-w64-ucrt-x86_64-crt mingw-w64-ucrt-x86_64-headers \
    mingw-w64-ucrt-x86_64-binutils mingw-w64-ucrt-x86_64-winpthreads \
    mingw-w64-ucrt-x86_64-gmp mingw-w64-ucrt-x86_64-mpfr \
    mingw-w64-ucrt-x86_64-mpc mingw-w64-ucrt-x86_64-isl
  cp -a /ucrt64 "$GCCDIR"
  base="https://repo.msys2.org/mingw/ucrt64"
  tmp="$(mktemp -d)"
  for pkg in gcc-14.2.0-3 gcc-libs-14.2.0-3; do
    curl -fsSL -o "$tmp/$pkg.pkg.tar.zst" \
      "$base/mingw-w64-ucrt-x86_64-$pkg-any.pkg.tar.zst"
    tar -C "$GCCDIR" --strip-components=1 --use-compress-program=zstd \
      -xf "$tmp/$pkg.pkg.tar.zst" ucrt64
  done
  rm -rf "$tmp"
fi
"$GCCDIR/bin/gcc.exe" --version | head -1

export PATH="$GCCDIR/bin:$(go env GOPATH)/bin:$PATH"
export CC="$(cygpath -w "$GCCDIR/bin/gcc.exe")"
export CXX="$(cygpath -w "$GCCDIR/bin/g++.exe")"
export CGO_ENABLED=1
export CGO_LDFLAGS="-static-libgcc -static-libstdc++ -Wl,-Bstatic -lwinpthread -Wl,-Bdynamic"
